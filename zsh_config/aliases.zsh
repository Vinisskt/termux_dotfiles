# Maven
alias mvnr="mvn spring-boot:run"
alias mvni="mvn clean install"
alias mvnt="mvn test"

# git
alias ga.="git add ."
alias gadd= "git add"
alias gcmt="git commit -m"
alias gps="git push origin main"
alias gpl="git pull origin main"
alias gst="git status"
alias garo="git remote add origin"

# zsh 
alias rzsh="source ~/.zshrc"
alias n="nvim"
alias aliases="cat ~/.config/zsh/zsh_config/aliases.zsh"
alias c="clear"
# sql
alias sqlr="sudo systemctl start mysql"
alias sqls="sudo systemctl status mysql"
alias sqlk="sudo systemctl stop mysql"

alias eti="eza --tree --icons"
alias eli="eza -la --icons"
# conectar ao termux via ssh
alias runtermux="ssh localhost -p 8022 -l termux"
